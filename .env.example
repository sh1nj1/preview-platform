# --- Domain ---
# Wildcard A record *.preview.example.com → this server must be in Route53
PREVIEW_DOMAIN=preview.example.com

# --- Let's Encrypt ---
ACME_EMAIL=ops@example.com

# --- AWS credentials (Route53 DNS-01 challenge) ---
# IAM permissions needed:
#   route53:ChangeResourceRecordSets
#   route53:ListHostedZonesByName
#   route53:GetChange
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_HOSTED_ZONE_ID=Z1234567890ABC

# --- Dashboard auth ---
# $ signs in the hash must be escaped as $$ for docker compose.
# Use this one-liner to generate a ready-to-paste value:
#
#   htpasswd -nb admin yourpassword | sed 's/\$/\$\$/g'
#
# Copy the output and paste it directly after DASHBOARD_AUTH=
DASHBOARD_AUTH=admin:$$2y$$05$$REPLACE_ME

# --- preview-api (registration service) ---
# Bearer token clients use to call api.<PREVIEW_DOMAIN>. Treat as a secret.
# Generate with:  openssl rand -hex 32
PREVIEW_API_TOKEN=replace-me-with-openssl-rand-hex-32
