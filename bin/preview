#!/usr/bin/env bash
# preview — register/unregister worktree dev servers with Traefik (file provider)
#
# Commands:
#   preview link [slug] [port]   register current worktree (slug = branch, port = auto)
#   preview unlink [slug]         remove registration
#   preview list                  list active previews for this project
#   preview url [slug]            print preview URL
#
# Environment overrides:
#   PREVIEW_DOMAIN          base domain                 (default: preview.example.com)
#   PREVIEW_DYNAMIC_DIR     Traefik dynamic directory   (default: /srv/preview-platform/dynamic)
#   PREVIEW_PORT_START      port pool lower bound       (default: 3001)
#   PREVIEW_PORT_END        port pool upper bound       (default: 3099)
#   PREVIEW_HOST_IP         override auto-detected IP   (default: first non-loopback IPv4)

set -euo pipefail

DYNAMIC_DIR="${PREVIEW_DYNAMIC_DIR:-/srv/preview-platform/dynamic}"
DOMAIN="${PREVIEW_DOMAIN:-preview.example.com}"
PORT_START="${PREVIEW_PORT_START:-3001}"
PORT_END="${PREVIEW_PORT_END:-3099}"

err() { echo "preview: $*" >&2; exit 1; }

slugify() {
  echo "$1" | tr 'A-Z' 'a-z' \
            | sed -e 's|[/_]|-|g' -e 's|[^a-z0-9-]||g' -e 's|--*|-|g' \
                  -e 's|^-||' -e 's|-$||'
}

current_project() {
  local root
  root="$(git rev-parse --show-toplevel 2>/dev/null)" \
    || err "not in a git repo"
  slugify "$(basename "$root")"
}

current_slug() {
  local branch
  branch="$(git branch --show-current 2>/dev/null)" \
    || err "cannot detect branch"
  [ -n "$branch" ] || err "detached HEAD; pass slug explicitly: preview link <slug>"
  slugify "$branch"
}

free_port() {
  local used
  used="$(ss -tln 2>/dev/null | awk 'NR>1 {n=split($4,a,":"); print a[n]}' | sort -u || true)"
  for ((p=PORT_START; p<=PORT_END; p++)); do
    if ! grep -qx "$p" <<< "$used"; then
      echo "$p"; return
    fi
  done
  err "no free port in ${PORT_START}-${PORT_END}"
}

host_ip() {
  if [ -n "${PREVIEW_HOST_IP:-}" ]; then
    echo "$PREVIEW_HOST_IP"; return
  fi
  ip -4 -o addr show scope global 2>/dev/null \
    | awk '{print $4}' | cut -d/ -f1 | head -1 \
    || hostname -I | awk '{print $1}'
}

filename_for() {
  local project="$1" slug="$2"
  echo "${DYNAMIC_DIR}/wt-${project}-${slug}.yml"
}

cmd_link() {
  local project slug port ip host file name
  project="$(current_project)"
  slug="$(slugify "${1:-$(current_slug)}")"
  port="${2:-$(free_port)}"
  ip="$(host_ip)"
  host="${slug}.${project}.${DOMAIN}"
  file="$(filename_for "$project" "$slug")"
  name="wt-${project}-${slug}"

  mkdir -p "$DYNAMIC_DIR"
  cat > "$file" <<EOF
http:
  routers:
    ${name}:
      rule: "Host(\`${host}\`)"
      entryPoints: [websecure]
      service: ${name}
      tls: {}
  services:
    ${name}:
      loadBalancer:
        servers:
          - url: "http://${ip}:${port}"
EOF
  echo "PORT=${port}" > .preview.env
  cat <<EOF
✓ linked
  URL:      https://${host}
  upstream: http://${ip}:${port}
  config:   ${file}
  env:      .preview.env (PORT=${port})

  Start your dev server with PORT=${port}:
    source .preview.env && npm run dev
    # or with direnv: 'use dotenv .preview.env' in .envrc
EOF
}

cmd_unlink() {
  local project slug file
  project="$(current_project)"
  slug="$(slugify "${1:-$(current_slug)}")"
  file="$(filename_for "$project" "$slug")"
  if [ -f "$file" ]; then
    rm -f "$file"
    echo "✓ unlinked ${slug}"
  else
    echo "no link found for ${slug}"
  fi
  rm -f .preview.env 2>/dev/null || true
}

cmd_list() {
  local project f slug upstream found=0
  project="$(current_project)"
  shopt -s nullglob
  for f in "$DYNAMIC_DIR"/wt-"$project"-*.yml; do
    found=1
    slug="$(basename "$f" .yml | sed "s|^wt-${project}-||")"
    upstream="$(awk -F'"' '/url:/ {print $2; exit}' "$f")"
    printf "  %-30s  %s\n" "$slug" "$upstream"
  done
  [ $found -eq 0 ] && echo "no active previews for ${project}"
}

cmd_url() {
  local project slug
  project="$(current_project)"
  slug="$(slugify "${1:-$(current_slug)}")"
  echo "https://${slug}.${project}.${DOMAIN}"
}

main() {
  local cmd="${1:-list}"
  case "$cmd" in
    link)        shift || true; cmd_link "$@" ;;
    unlink|rm)   shift || true; cmd_unlink "$@" ;;
    list|ls)     cmd_list ;;
    url)         shift || true; cmd_url "$@" ;;
    -h|--help|help)
      sed -n '2,12p' "$0" | sed 's|^# \?||'
      ;;
    *) err "unknown command: $cmd (try: preview help)" ;;
  esac
}

main "$@"
