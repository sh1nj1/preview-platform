#!/usr/bin/env bash
# preview installer — fetches the preview CLI binary from the API server
# and writes ~/.config/preview/config so subsequent `preview` commands
# work without env vars.
#
# Usage:
#   curl -fsSL -H "Authorization: Bearer <TOKEN>" https://api.<domain>/install.sh | bash
#   curl -fsSL -H "Authorization: Bearer <TOKEN>" https://api.<domain>/install.sh | bash -s -- --with-skill
#   curl -fsSLk -H "Authorization: Bearer <TOKEN>" https://api.<domain>/install.sh | bash -s -- --insecure

set -euo pipefail

ENDPOINT="{{.Endpoint}}"
TOKEN="{{.Token}}"
WITH_SKILL=0
INSECURE=0
INSTALL_DIR="${PREVIEW_INSTALL_DIR:-$HOME/.local/bin}"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/preview"

for arg in "$@"; do
  case "$arg" in
    --with-skill) WITH_SKILL=1 ;;
    --insecure)   INSECURE=1 ;;
    --prefix=*)   INSTALL_DIR="${arg#--prefix=}" ;;
    *) echo "unknown flag: $arg" >&2; exit 2 ;;
  esac
done

CURL_OPTS=(-f -s -S -L)
[ "$INSECURE" = 1 ] && CURL_OPTS+=(-k)

uname_os() {
  local s
  s="$(uname -s | tr '[:upper:]' '[:lower:]')"
  case "$s" in
    linux*)  echo linux ;;
    darwin*) echo darwin ;;
    *) echo "unsupported OS: $s" >&2; exit 1 ;;
  esac
}

uname_arch() {
  local m
  m="$(uname -m)"
  case "$m" in
    x86_64|amd64) echo amd64 ;;
    arm64|aarch64) echo arm64 ;;
    *) echo "unsupported arch: $m" >&2; exit 1 ;;
  esac
}

OS="$(uname_os)"
ARCH="$(uname_arch)"

echo "==> Downloading preview CLI for ${OS}/${ARCH}"
mkdir -p "$INSTALL_DIR" "$CONFIG_DIR"
TMP="$(mktemp)"
trap 'rm -f "$TMP"' EXIT
curl "${CURL_OPTS[@]}" -H "Authorization: Bearer ${TOKEN}" \
  "${ENDPOINT}/bin/preview/${OS}/${ARCH}" -o "$TMP"
install -m 0755 "$TMP" "${INSTALL_DIR}/preview"

echo "==> Writing ${CONFIG_DIR}/config"
umask 077
{
  echo "endpoint=${ENDPOINT}"
  echo "token=${TOKEN}"
  [ "$INSECURE" = 1 ] && echo "insecure=true"
} > "${CONFIG_DIR}/config"

if [ "$WITH_SKILL" = 1 ]; then
  SKILL_DIR="${HOME}/.claude/skills/preview"
  echo "==> Installing Claude Code skill into ${SKILL_DIR}"
  mkdir -p "$SKILL_DIR"
  curl "${CURL_OPTS[@]}" -H "Authorization: Bearer ${TOKEN}" \
    "${ENDPOINT}/skills/preview" -o "${SKILL_DIR}/SKILL.md"
fi

cat <<EOF

==> Installed.
   binary:  ${INSTALL_DIR}/preview
   config:  ${CONFIG_DIR}/config
$( [ "$WITH_SKILL" = 1 ] && echo "   skill:   ${HOME}/.claude/skills/preview/SKILL.md" )

If ${INSTALL_DIR} is not in PATH, add it:
  export PATH="${INSTALL_DIR}:\$PATH"

Try it:
  cd <your repo worktree>
  preview link

EOF
